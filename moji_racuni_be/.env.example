# Django core
DJANGO_SECRET_KEY=django-insecure-dev-only-change-me
DJANGO_DEBUG=True
# Add your machine IP if you access backend from another device on LAN
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver

# CORS
# For local development it is acceptable to allow all origins.
# For stricter local setup set this to False and configure CORS_ALLOWED_ORIGINS.
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DB_NAME=moji_racuni
DB_USER=root
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=3306
